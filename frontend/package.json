{
  "name": "frontend",
  "version": "0.1.0",
  "description": "Precis - Visual Editor Frontend (Vue 3 + Vue Flow)",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "author": "Precis Team",
  "keywords": [
    "precis",
    "data-validation",
    "vue",
    "vue-flow",
    "visual-editor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AirSaiga/Precis.git",
    "directory": "frontend"
  },
  "bugs": {
    "url": "https://github.com/AirSaiga/Precis/issues"
  },
  "homepage": "https://github.com/AirSaiga/Precis#readme",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "audit:styles": "node ./scripts/audit-hardcoded-styles.mjs",
    "audit:i18n": "node ./scripts/audit-i18n.mjs",
    "audit:i18n:update": "node ./scripts/audit-i18n.mjs --update-baseline",
    "codegen": "node ./scripts/codegen.mjs",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix && npm run audit:styles && npm run audit:i18n",
    "lint:check": "eslint . --max-warnings=319 && npm run audit:styles && npm run audit:i18n",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-yaml": "^6.1.2",
    "@lucide/vue": "~1.0.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.0",
    "@vue-flow/minimap": "^1.5.4",
    "axios": "^1.18.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.12",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "js-yaml": "^4.2.1",
    "jspdf": "^4.2.0",
    "lodash-es": "^4.17.21",
    "markdown-it": "^14.3.0",
    "mitt": "^3.0.1",
    "pinia": "^3.0.3",
    "uuid": "^14.0.0",
    "vue": "^3.5.22",
    "vue-codemirror": "^6.1.1",
    "vue-i18n": "^11.4.4",
    "vue-router": "^4.5.1"
  },
  "overrides": {
    "shell-quote": "^1.10.0",
    "minimatch@3.1.5": {
      "brace-expansion": "^1.1.16"
    },
    "minimatch@9": {
      "brace-expansion": "^2.1.2"
    }
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.18.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "~10.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.5.1",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^9.0.1",
    "prettier": "^3.8.3",
    "typescript": "~5.9.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.1.0"
  }
}
