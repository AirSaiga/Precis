{
  "composite": true,
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx"
  ],
  "exclude": ["src/**/__tests__/*", "src/废弃/**"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".", // 必须配置，通常为项目根目录
    "paths": {
      "@/*": ["./src/*"]
    },

    // 将 strict 改为 false，或者保持 true 但手动关闭以下细节：
    "strict": true,

    // 1. 允许隐式的 any 类型
    // 开启这个后，如果你没写类型，TS 不会报错，而是默认它是 any
    "noImplicitAny": false,

    // 2. 关闭严格空检查 (最推荐关闭这个缓解痛苦)
    // 开启必须处理 null/undefined。关闭后，object.prop 不会报 "可能是 undefined"
    "strictNullChecks": true,

    // 3. 允许 this 推断为 any
    "noImplicitThis": false
  }
}
