# Precis 环境变量示例
# 复制此文件为 .env 并填入实际值

# ⚠️ 安全提示：
# - .env 必须被 .gitignore 忽略（确认仓库根 .gitignore 含 .env）
# - 真实 API key 授予计费访问权，泄露后应立即在对应平台轮换
# - 此文件仅作示例，切勿填入真实凭据后提交到版本控制

# 后端端口（开发模式）
VITE_BACKEND_PORT=18000

# 前端开发服务器端口
VITE_FRONTEND_PORT=5173

# AI Provider API Key（可选）
# OPENAI_API_KEY=your-api-key-here
