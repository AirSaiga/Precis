cd frontend && npx lint-staged

cd ..
# 仅对暂存区中新增/修改的 Python 文件执行 ruff 检查和格式化
# 在仓库根目录执行，避免相对路径错位
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
if [ -n "$STAGED_PY_FILES" ]; then
  echo "$STAGED_PY_FILES" | xargs -d '\n' python -m ruff check --fix
  echo "$STAGED_PY_FILES" | xargs -d '\n' python -m ruff format
  # ruff 修改了磁盘文件，需重新暂存，否则提交的是未修复版本（与 lint-staged 行为一致）
  echo "$STAGED_PY_FILES" | xargs -d '\n' git add
fi
