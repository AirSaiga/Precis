{
  "name": "precis-desktop",
  "version": "0.1.0",
  "description": "Precis Desktop Application - Data Validation Tool",
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/AirSaiga/Precis.git",
    "directory": "electron"
  },
  "bugs": {
    "url": "https://github.com/AirSaiga/Precis/issues"
  },
  "homepage": "https://github.com/AirSaiga/Precis#readme",
  "scripts": {
    "start": "node scripts/start.js",
    "dev": "electron .",
    "pack": "powershell -ExecutionPolicy Bypass -File scripts/build.ps1 -Target pack",
    "dist": "powershell -ExecutionPolicy Bypass -File scripts/build.ps1 -Target dist",
    "release": "powershell -ExecutionPolicy Bypass -File scripts/build.ps1 -Target release",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/enable-dev-mode.ps1",
    "lint": "eslint --ext .ts,.js .",
    "build:electron": "tsc",
    "build:backend": "cd ../backend && python -m pip install -e .",
    "build:frontend": "cd ../frontend && npm run build",
    "build:all": "npm run build:backend && npm run build:frontend && npm run build:electron && npm run dist"
  },
  "keywords": [
    "electron",
    "precis",
    "validation"
  ],
  "author": "Precis Team",
  "license": "Apache-2.0",
  "build": {
    "appId": "com.precis.desktop",
    "productName": "Precis",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "backend/**/*",
      "!backend/build_backend.py",
      "!backend/requirements-build.txt",
      "!backend/precis-backend.spec",
      "!backend/__pycache__/**",
      "!backend/**/__pycache__/**",
      "!backend/app/**/__pycache__/**"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "AirSaiga",
      "repo": "Precis"
    },
    "win": {
      "target": {
        "target": "nsis",
        "arch": ["x64"]
      },
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052"
    }
  },
  "devDependencies": {
    "@types/node": "^22.18.6",
    "cross-env": "^10.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "typescript": "~5.9.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "electron-updater": "^6.3.9"
  }
}
