{
  "name": "precis-desktop",
  "version": "0.1.0",
  "description": "Precis Desktop Application - Data Validation Tool",
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/AirSaiga/Precis.git",
    "directory": "electron"
  },
  "bugs": {
    "url": "https://github.com/AirSaiga/Precis/issues"
  },
  "homepage": "https://github.com/AirSaiga/Precis#readme",
  "scripts": {
    "start": "node scripts/start.js",
    "start:base": "electron-forge start",
    "start:utf8": "cmd /c chcp 65001 >nul && electron-forge start",
    "start:debug": "electron-forge start --inspect-electron",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.js .",
    "build:electron": "tsc",
    "build:backend": "cd ../backend && python build_backend.py",
    "build:frontend": "cd ../frontend && npm run build",
    "build:all": "npm run build:backend && npm run build:frontend && npm run build:electron"
  },
  "keywords": [
    "electron",
    "precis",
    "validation"
  ],
  "author": "Precis Team",
  "license": "Apache-2.0",
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "Precis",
        "productName": "Precis",
        "appId": "com.precis.desktop",
        "asar": true,
        "directories": {
          "output": "release"
        },
        "files": [
          "dist/**/*",
          "backend/**/*",
          "!backend/build_backend.py",
          "!backend/requirements-build.txt",
          "!backend/precis-backend.spec",
          "!backend/__pycache__/**",
          "!backend/**/__pycache__/**",
          "!backend/app/**/__pycache__/**"
        ],
        "extraResources": [
          {
            "from": "../frontend/dist",
            "to": "frontend/dist"
          }
        ],
        "win": {
          "target": "nsis",
          "icon": "assets/icon.ico"
        },
        "mac": {
          "target": "dmg",
          "icon": "assets/icon.icns"
        },
        "linux": {
          "target": "AppImage",
          "icon": "assets/icon.png"
        }
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "precis_desktop"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {}
        },
        {
          "name": "@electron-forge/maker-rpm",
          "config": {}
        }
      ],
      "plugins": [
        {
          "name": "@electron-forge/plugin-auto-unpack-natives",
          "config": {}
        }
      ]
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.6.0",
    "@types/node": "^22.18.6",
    "electron": "^35.0.0",
    "typescript": "~5.9.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3"
  }
}
