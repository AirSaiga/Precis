{
  "name": "precis-desktop",
  "version": "0.1.0",
  "description": "Precis Desktop Application - Data Validation Tool",
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/AirSaiga/Precis.git",
    "directory": "electron"
  },
  "bugs": {
    "url": "https://github.com/AirSaiga/Precis/issues"
  },
  "homepage": "https://github.com/AirSaiga/Precis#readme",
  "scripts": {
    "start": "node scripts/start.js",
    "start:base": "electron .",
    "dev": "electron .",
    "pack": "powershell -ExecutionPolicy Bypass -File scripts/build.ps1 -Target pack",
    "dist": "powershell -ExecutionPolicy Bypass -File scripts/build.ps1 -Target dist",
    "dist:mac": "cd .. && bash scripts/build-mac.sh",
    "release": "powershell -ExecutionPolicy Bypass -File scripts/build.ps1 -Target release",
    "fetch-python": "node scripts/fetch-python.js",
    "install:backend-deps": "node scripts/install-backend-deps.js",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/enable-dev-mode.ps1",
    "lint": "eslint src",
    "build:electron": "npx tsc",
    "build:backend": "cd ../backend && python -m pip install -e \".[api]\"",
    "build:frontend": "cd ../frontend && npm run build",
    "build:all": "npm run build:backend && npm run build:frontend && npm run build:electron && npm run dist",
    "icon": "node scripts/convert-icon.mjs",
    "update:local": "node scripts/create-local-update.js create",
    "serve:updates": "node scripts/serve-updates.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "electron",
    "precis",
    "validation"
  ],
  "author": "Precis Team",
  "license": "Apache-2.0",
  "build": {
    "appId": "com.precis.desktop",
    "productName": "Precis",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      },
      {
        "from": "resources/python-runtime",
        "to": "python-runtime"
      },
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__",
          "!__pycache__/**",
          "!**/__pycache__",
          "!**/__pycache__/**",
          "!.mypy_cache",
          "!.mypy_cache/**",
          "!.pytest_cache",
          "!.pytest_cache/**",
          "!.ruff_cache",
          "!.ruff_cache/**",
          "!.coverage",
          "!*.egg-info",
          "!*.egg-info/**",
          "!build",
          "!build/**",
          "!dist",
          "!dist/**",
          "!tests",
          "!tests/**",
          "!.git",
          "!.git/**",
          "!.gitignore"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "AirSaiga",
      "repo": "Precis"
    },
    "win": {
      "target": {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052"
    }
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.18.6",
    "cross-env": "^10.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "png2icons": "^2.0.1",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "electron-updater": "^6.8.9",
    "js-yaml": "^4.1.0",
    "sharp": "^0.34.5"
  }
}
